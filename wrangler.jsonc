{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "issue-refiner",
  "main": "src/index.js",
  "compatibility_date": "2026-06-08",
  "compatibility_flags": ["nodejs_compat"],
  "kv_namespaces": [
    {
      "binding": "KV",
      "id": "48a76ced34eb4732bb5a9477e43dc3db",
    },
  ],
  "vars": {
    "ALLOWED_GUILD_ID": "<DISCORD_GUILD_ID>",
    "CHANNEL_REPO_MAP_JSON": "{\"guilds\":{\"<DISCORD_GUILD_ID>\":{\"channels\":{\"<CHANNEL_ID>\":\"owner/repo\"}}}}",
    "OPENAI_MODEL": "gpt-5.4-nano",
  },
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1,
  },
}
